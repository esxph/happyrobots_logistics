# API authentication (HappyRobot workflow calls this service)
API_KEY=change-me-to-a-strong-secret

# Server
PORT=8080
HOST=0.0.0.0

# Legacy TMS (TCP) — host:port from operations contact
TMS_HOST=
TMS_PORT=
TMS_AUTH_TOKEN=
TMS_CONNECT_TIMEOUT_MS=5000
TMS_READ_TIMEOUT_MS=10000
TMS_MAX_RETRIES=3
TMS_CACHE_ENABLED=true
TMS_CACHE_TTL_SECONDS=45

# FMCSA QCMobile API
FMCSA_WEB_KEY=
FMCSA_BASE_URL=https://mobile.fmcsa.dot.gov/qc/services

# OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# Twin data layer (JSON file store + optional HappyRobot Context/Twin sync)
TWIN_DATA_DIR=./data/twin

# HappyRobot platform API key — dual-writes call logs to Context/Twin on every log_call
# Get from builder.happyrobot.ai → Settings → Profile → Generate API Key
HP_API=
HP_BASE_URL=https://platform.happyrobot.ai/api/v2
HP_TWIN_TABLE=carrier_calls
HP_TWIN_SYNC=true

# Return OTP code + full phone in send_otp response (POC / HappyRobot SMS). Set false in production.
OTP_RETURN_CODE_IN_RESPONSE=true

# Optional: override carrier phone for OTP when FMCSA record has no telephone field
OTP_PHONE_OVERRIDE=

# Demo carrier for voice testing (authorized + OTP phone; bypasses FMCSA)
DEMO_MC_NUMBER=999999
DEMO_MC_LEGAL_NAME=HappyRobot Demo Carrier
DEMO_MC_DOT=1234567
DEMO_MC_PHONE=+525510506746
